#!/bin/bash
# Post-commit hook: feature 分支 commit 成功后的提醒

BRANCH=$(git rev-parse --abbrev-ref HEAD)
PROTECTED_BRANCHES=("main" "master")

# 如果是 protected 分支，说明 pre-commit 没拦住（不应该发生）
if [[ " ${PROTECTED_BRANCHES[*]} " == *" ${BRANCH} "* ]]; then
    echo "⚠️ 警告：你直接在 ${BRANCH} 分支上 commit 了！"
    echo "建议通过 PR 合并代码。参考 docs/competition-rules.md"
    exit 0
fi

echo "✅ Commit 成功（分支: ${BRANCH}）"
echo "💡 提醒：完成后请 push 到远程并创建 PR"
echo "   git push origin ${BRANCH} -u"
